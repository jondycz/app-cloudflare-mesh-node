#!/command/with-contenv bashio
# shellcheck shell=bash
export LOG_FD
# ==============================================================================
# Home Assistant Community App: Cloudflare WARP Mesh Node
# Clamp the MSS to the MTU
# ==============================================================================

readonly WARP_INTERFACE="CloudflareWARP"
readonly CLAMPING_IPTABLES_OPTIONS="-p tcp -m tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu"

# Clamp the MSS to the MTU for WARP's interface
# This supports site-to-site networking better
function setup_clamping() {
  local cmd="$1"
  local ip_version="$2"

  bashio::log.info "Clamping the MSS to the MTU for interface ${WARP_INTERFACE}," \
    "to support site-to-site networking better (${ip_version})"
  if ${cmd} -t mangle -S FORWARD \
    | grep -Eq "^-A FORWARD -o CloudflareWARP ${CLAMPING_IPTABLES_OPTIONS}$"
  then
    bashio::log.notice "Clamping is already set (${ip_version})"
  else
    if ! ${cmd} -t mangle -A FORWARD -o ${WARP_INTERFACE} ${CLAMPING_IPTABLES_OPTIONS}; then
      bashio::log.warning "Setting up clamping is unsuccessful (${ip_version})"
    fi
  fi
}

setup_clamping "iptables" "IPv4"
setup_clamping "ip6tables" "IPv6"
